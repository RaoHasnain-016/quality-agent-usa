PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200
RATE_LIMIT_MAX=1000

# Local MongoDB Compass / MongoDB service
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=agentic_qa

# Local backend JWT auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Optional Firebase Admin support for Firebase ID tokens
FIREBASE_PROJECT_ID=agentqa-xxxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@agentqa.iam.gserviceaccount.com

# Local works without an external API. Use "gemini" for stronger LLM evaluation.
AI_PROVIDER=local
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
EVAL_CHUNK_SIZE=5
EVAL_CHUNK_DELAY_MS=100

# Optional email alerts
RESEND_API_KEY=re_YOUR_KEY_HERE
ALERT_FROM_EMAIL="AgentQA Alerts <alerts@agentqa.io>"

# Stripe subscriptions
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET
STRIPE_PRICE_STARTER=price_YOUR_STARTER_PRICE
STRIPE_PRICE_PRO=price_YOUR_PRO_PRICE
STRIPE_PRICE_TEAM=price_YOUR_TEAM_PRICE
