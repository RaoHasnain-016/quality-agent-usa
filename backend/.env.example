PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:4300
RATE_LIMIT_MAX=300

# Required for database-backed API routes
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/agentqa

# Local backend JWT auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Optional Firebase Admin support for Firebase ID tokens
FIREBASE_PROJECT_ID=agentqa-xxxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@agentqa.iam.gserviceaccount.com

# Required for automatic LLM evaluation
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash
EVAL_CHUNK_SIZE=3
EVAL_CHUNK_DELAY_MS=1000

# Optional email alerts
RESEND_API_KEY=re_YOUR_KEY_HERE
ALERT_FROM_EMAIL="AgentQA Alerts <alerts@agentqa.io>"
